/* RESET */

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family: 'Poppins', sans-serif;
background:#0f172a;
color:#e2e8f0;
line-height:1.6;
}

/* NAVBAR */

.navbar{
position:fixed;
width:100%;
top:0;
background:#020617;
border-bottom:1px solid #1e293b;
z-index:1000;
}

.navbar-inner{
max-width:1200px;
margin:auto;
display:flex;
align-items:center;
justify-content:space-between;
padding:15px 20px;
}

.brand{
display:flex;
align-items:center;
gap:10px;
text-decoration:none;
color:white;
}

.brand img{
width:40px;
border-radius:50%;
}

.nav-menu{
display:flex;
gap:25px;
list-style:none;
}

.nav-link{
color:#cbd5f5;
text-decoration:none;
font-weight:500;
transition:.3s;
}

.nav-link:hover{
color:#38bdf8;
}

/* HERO */

.hero{
max-width:1200px;
margin:auto;
padding:150px 20px 80px;
display:grid;
grid-template-columns:1fr 1fr;
gap:50px;
align-items:center;
}

.hero-title{
font-size:48px;
font-weight:700;
}

.hero-subtitle{
margin-top:20px;
font-size:18px;
color:#94a3b8;
}

.hero-actions{
margin-top:30px;
display:flex;
gap:15px;
}

.btn{
padding:12px 22px;
border-radius:8px;
text-decoration:none;
font-weight:600;
}

.btn-primary{
background:#38bdf8;
color:#020617;
}

.btn-primary:hover{
background:#0ea5e9;
}

.btn-ghost{
border:1px solid #38bdf8;
color:#38bdf8;
}

/* SECTIONS */

.section{
max-width:1200px;
margin:auto;
padding:100px 20px;
}

.section-title{
font-size:36px;
margin-bottom:20px;
}

.section-description{
color:#94a3b8;
max-width:600px;
}

/* CARDS */

.skills-grid,
.projects-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;
margin-top:50px;
}

.skill-card,
.project-card{
background:#020617;
border:1px solid #1e293b;
padding:25px;
border-radius:12px;
transition:.3s;
}

.skill-card:hover,
.project-card:hover{
transform:translateY(-5px);
border-color:#38bdf8;
}

/* PROJETOS */

.project-thumb img{
width:100%;
border-radius:10px;
}

.project-title{
margin-top:15px;
font-size:20px;
}

/* CONTATO */

.contact{
background:#020617;
padding:80px 20px;
text-align:center;
}

.contact-title{
font-size:32px;
margin-bottom:20px;
}

.contact-email{
display:inline-flex;
gap:10px;
padding:12px 20px;
background:#38bdf8;
color:#020617;
text-decoration:none;
border-radius:8px;
font-weight:600;
}

/* FOOTER */

footer{
border-top:1px solid #1e293b;
padding:30px 20px;
text-align:center;
color:#94a3b8;
}